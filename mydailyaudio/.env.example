# Database
DATABASE_URL=sqlite:///./mydailyaudio.db

# JWT
SECRET_KEY=change-this-to-a-strong-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# LLM Providers (优先级按环境变量或 profiles.json 配置)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=stepfun/step-3.5-flash:free

# Optional alternatives
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# HF_API_KEY=hf_...

# Telegram defaults (each user can override per profile)
TELEGRAM_BOT_TOKEN_DEFAULT=
TELEGRAM_CHAT_ID_DEFAULT=

# GitHub Pages
GITHUB_REPO_NAME=mydailyaudio

# Report Engine
DATA_DIR=./data